pkgbase = lcdiff
	pkgdesc = Inspect, compare, and merge JAR/ZIP archives and folders
	pkgver = 0.3.0
	pkgrel = 1
	url = https://github.com/lyokha113/lcdiff
	arch = x86_64
	license = MIT
	makedepends = cargo
	makedepends = git
	makedepends = jdk17-openjdk
	makedepends = maven
	makedepends = nodejs
	makedepends = npm
	makedepends = rust
	depends = cairo
	depends = desktop-file-utils
	depends = gdk-pixbuf2
	depends = glib2
	depends = gtk3
	depends = hicolor-icon-theme
	depends = libappindicator-gtk3
	depends = librsvg
	depends = libsoup
	depends = openssl
	depends = pango
	depends = webkit2gtk-4.1
	depends = xdotool
	options = !strip
	install = lcdiff.install
	source = git+https://github.com/lyokha113/lcdiff.git#tag=v0.3.0
	sha256sums = SKIP
