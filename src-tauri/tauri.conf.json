{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LCDiff",
  "version": "0.2.1",
  "identifier": "dev.lcdiff.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LCDiff",
        "width": 1280,
        "height": 900
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "resources": ["resources"]
  }
}
