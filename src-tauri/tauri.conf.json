{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LCDiff",
  "version": "0.3.5",
  "identifier": "dev.lcdiff.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' asset: http://asset.localhost; img-src 'self' asset: http://asset.localhost data:; connect-src ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/Library/Fonts/**",
          "/Library/Fonts/**",
          "/System/Library/Fonts/**"
        ]
      }
    },
    "windows": [
      {
        "title": "LCDiff",
        "width": 1280,
        "height": 900
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.png"],
    "fileAssociations": [
      {
        "ext": ["jar", "zip", "war", "ear"],
        "name": "LCDiff archive source",
        "description": "JAR, ZIP, WAR, and EAR archives",
        "role": "Viewer"
      },
      {
        "ext": [
          "txt",
          "text",
          "log",
          "json",
          "xml",
          "properties",
          "yaml",
          "yml",
          "md",
          "csv",
          "ini",
          "cfg",
          "conf"
        ],
        "name": "LCDiff text source",
        "description": "Text files",
        "role": "Viewer"
      }
    ],
    "resources": ["resources"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1NURCNTQ4OEY1OThCNkQKUldSdGkxbVBTTFZkNWFCTEExdVBhTXprazFIbUI3RGNWZFNpNWdOMTBUYjc0K2dYblJ2OGtRWW0K",
      "endpoints": [
        "https://github.com/lyokha113/lcdiff/releases/latest/download/latest-{{target}}-{{arch}}.json"
      ]
    }
  }
}
